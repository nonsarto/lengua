# lengua — Vorlage. Kopiere nach .env und fülle die Werte. NIE committen (.env ist gitignored).

# Claude API (Slice 0+)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (Slice 1+) — Projekt-Dashboard → Settings → API
# URL:            "Project URL"
# SERVICE_ROLE:   "service_role secret" (NICHT der anon key — der Backend-Server ist der einzige Writer)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
